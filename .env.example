# ── DataSense AI — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is already in .gitignore.

# ── AI / LLM ─────────────────────────────────────────────────────────
# Get your free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database (PostgreSQL) ─────────────────────────────────────────────
# For local Docker setup:
DATABASE_URL=postgresql://datasense:your_db_password@db:5432/datasense
POSTGRES_USER=datasense
POSTGRES_PASSWORD=your_db_password_here

# For Supabase (cloud):
# DATABASE_URL=postgresql://postgres.[your-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── App Settings ─────────────────────────────────────────────────────
# Set to "production" when deploying
APP_ENV=development

# ── Optional: Stripe for payments ────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
